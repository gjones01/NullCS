# NullCS backend environment example
# Copy this file to .env for local/private use. Do not commit real secrets.

NULLCS_ENV=development
NULLCS_DEMO_MODE=0
NULLCS_DESKTOP_MODE=0

# Private backend auth. Use a long random value in production/private deployments.
NULLCS_API_KEY=replace-with-a-long-random-secret

# Restrict production CORS to your actual frontend origin.
NULLCS_FRONTEND_ORIGIN=http://127.0.0.1:5173

# Optional path overrides
# NULLCS_PROJECT_ROOT=C:\NullCS
# CLARITY_PYTHON_EXE=C:\Path\To\python.exe
# NULLCS_UPLOAD_DIR=C:\NullCS\main\data\raw_uploads
# CLARITY_PROCESSED_DIR=C:\NullCS\main\data\processed
# CLARITY_MODEL_ARTIFACT=xgb_player_level_cs2cd.json

# Optional limits/timeouts
# NULLCS_MAX_UPLOAD_BYTES=0
# NULLCS_REQUEST_TIMEOUT_SECONDS=30
# NULLCS_JOB_TIMEOUT_SECONDS=1800
# NULLCS_EXPLAIN_TIMEOUT_SECONDS=120
