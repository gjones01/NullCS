{
  "name": "nullcs-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "desktop:dev": "set PATH=%USERPROFILE%\\.cargo\\bin;%PATH%&& tauri dev",
