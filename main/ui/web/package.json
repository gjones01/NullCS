    "desktop:info": "set PATH=%USERPROFILE%\\.cargo\\bin;%PATH%&& tauri info",
    "desktop:check": "set PATH=%USERPROFILE%\\.cargo\\bin;%PATH%&& cargo check --manifest-path src-tauri/Cargo.toml"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
